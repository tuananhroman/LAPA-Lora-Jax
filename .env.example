# =====================================================================
# LAPA LoRA-JAX  —  environment template
# Run `bash scripts/setup.sh` to auto-generate .env with real paths,
# OR copy this file to .env and fill in the values manually.
# =====================================================================

# --- Host paths (auto-filled by setup.sh; adjust to your layout) ------
# Directory containing LAPA-7B base checkpoint (params, tokenizer.model, vqgan).
# Inside the container this is mounted at /checkpoints (read-only).
LAPA_CHECKPOINT_DIR=./checkpoints

# Directory for preprocessed training data (train.jsonl + image frames).
# Populated by: docker compose run --rm preprocess
# Mounted at /data (read-only).
LAPA_DATA_DIR=./data/libero90_jsonl_v2

# Directory containing raw LIBERO-90 HDF5 demos.
# Used only by the preprocess step; mounted at /raw_data (read-only).
LAPA_RAW_DATA_DIR=./data/raw

# Directory for saved LoRA checkpoints, logs, wandb offline runs.
# Mounted at /workspace/outputs (writable).
LAPA_OUTPUT_DIR=./outputs

# XLA persistent JIT cache — huge speedup on restarts (writable).
# Defaults to ./.cache/jax_compile inside the repo if unset.
# LAPA_CACHE_DIR=./.cache/jax_compile

# --- GPU / compute ---------------------------------------------------
CUDA_VISIBLE_DEVICES=0,1,2,3
XLA_PYTHON_CLIENT_MEM_FRACTION=0.82

# --- WandB -----------------------------------------------------------
# Get key from https://wandb.ai/authorize  (leave blank to disable)
WANDB_API_KEY=
WANDB_PROJECT=lapa-lora-jax
WANDB_ENTITY=
WANDB_MODE=online           # online | offline | disabled
WANDB_RUN_NAME=lapa_lora_libero90_v2

# --- Config ----------------------------------------------------------
# Which YAML under configs/ to load. See configs/libero90_lora_v2.yaml.
LAPA_CONFIG=libero90_lora_v2.yaml
